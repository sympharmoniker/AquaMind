# AquaMind 環境變數設定檔 — 範本
#
# 用法:
#   1. 複製此檔到家目錄: cp ~/AquaMind/setup/aquamind_config.env.example ~/aquamind_config.env
#   2. 編輯 ~/aquamind_config.env 填入真實 key
#   3. 鎖權限: chmod 600 ~/aquamind_config.env(只有自己能讀)
#   4. 改 crontab 改用這個檔(見下),把原本寫死的 key 那行刪掉
#
# crontab -e,把原本的環境變數那行刪掉,daily_report 那行改成:
#   0 8 * * * cd /home/rasppi/AquaMind/analysis && . /home/rasppi/aquamind_config.env && /usr/bin/python3 daily_report.py && /usr/bin/python3 ai_report_email.py >> /tmp/cron_daily.log 2>&1
#
# 規則 #6 提醒:此檔(填好真值的那份)永遠不能進 git。
#   .gitignore 已設好排除 aquamind_config.env(只允許 .example 進 git)

# === Gemini / Google AI Studio API key ===
# 從 https://aistudio.google.com/apikey 拿新的(舊的若有疑慮先廢)
export GEMINI_API_KEY=請貼新的key在這裡

# === 之後若有別的敏感字串也加進來 ===
# export SMTP_PASSWORD=...
# export GOOGLE_SHEET_CSV_URL=...
